# Zhaoping 本地环境变量模板。
# 只把真实值填写到 .env。不要把真实密钥提交到 git。

# 本地 env 文件路径。默认读取项目根目录 .env。
ROBOT_AGENT_ENV_PATH=

# 本地运行环境。设置为 test 时，真实邮件发送优先走 Mailtrap 沙箱。
APP_ENV=

# 是否允许非本机请求写入 env。默认不要开启；公开/Cloudflare 访问时保持为空。
ALLOW_REMOTE_ENV_SAVE=

# ================================
# 基础大模型 / 评估能力
# ================================
# OpenRouter：默认大模型 provider。
# 对应服务：openrouter_auto_reasoning、openrouter_online_research、openrouter_evidence_judge。
OPENROUTER_API_KEY=

# 单个长链路任务的累计 Token 预算。超过后 JSON workflow 会熔断并等待人工处理。
ZHAOPING_TASK_TOKEN_BUDGET=50000

# Anthropic 兼容备用接口。
# 对应服务：token_plan_anthropic。
ANTHROPIC_COMPATIBLE_API_KEY=

# ================================
# OCR / 文档解析
# ================================
# 阿里云 OCR：简历、图片、扫描件文本识别。
# 对应服务：aliyun_ocr。
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ================================
# 已接入搜索：开放网页 / 代码 / 模型 / 监管 / 招聘信号
# ================================
# Brave Web Search：开放网页证据检索。
# 对应服务：brave_web_search。
BRAVE_SEARCH_API_KEY=

# GitHub：仓库搜索，用于找开源项目、贡献者、语言和技术栈信号。
# 对应服务：github_repositories。当前使用个人访问令牌；GitHub App 需要另接 installation token。
GITHUB_TOKEN=

# Hugging Face：模型生态搜索，用于找模型作者、下载量、标签和任务类型。
# 对应服务：huggingface_models。
HF_TOKEN=

# GNews：融资、并购、投资和新闻事件。
# 对应服务：gnews_funding_news。
GNEWS_API_KEY=

# SAM.gov：美国政府合同机会。
# 对应服务：sam_gov_opportunities。
SAM_GOV_API_KEY=

# FRED：宏观经济序列和最新观测值。
# 对应服务：fred_series_search。
FRED_API_KEY=

# CourtListener：美国司法、判例和诉讼检索。
# 对应服务：courtlistener_search。
COURTLISTENER_TOKEN=

# Companies House：英国公司注册信息。
# 对应服务：companies_house_search。
COMPANIES_HOUSE_API_KEY=

# USAJOBS：美国联邦岗位和薪酬信号。
# 对应服务：usajobs_search。USAJOBS_USER_AGENT 使用申请 API key 时填写的邮箱。
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# U.S. Census：国际贸易进出口数据。2026 年起 Census Data API 查询必须带 API key。
# 对应服务：census_international_trade。
CENSUS_API_KEY=

# ================================
# 新增建议：开放网页 / AI 搜索补强
# ================================
# Exa：语义网页搜索和网页内容抓取，适合找个人主页、项目页、实验室页和技术博客。
EXA_API_KEY=

# Tavily：面向 Agent 的网页搜索 API，适合作为 Brave/Exa 之外的备选搜索源。
TAVILY_API_KEY=

# Google Programmable Search：Google 自定义搜索 JSON API。需要 API key 和搜索引擎 ID。
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# SerpAPI：商业搜索结果 API，可作为 Google/Bing 等搜索结果聚合备选。使用前确认成本和条款。
SERPAPI_API_KEY=

# ================================
# 新增建议：学术 / 论文 / 作者身份
# ================================
# Semantic Scholar：论文、作者、引用图谱，用于找 AI/机器人/硬件方向研究人才。
SEMANTIC_SCHOLAR_API_KEY=

# arXiv：公开论文元数据 API 通常不需要 key，但建议配置清晰 User-Agent 便于合规访问。
ARXIV_USER_AGENT=

# OpenReview：ICLR/NeurIPS 等会议投稿、作者、评审公开信息。登录态能力需要账号凭据。
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=

# ORCID：研究人员身份标识和公开履历搜索。需要按 ORCID 流程申请 client。
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# IEEE Xplore：AI 硬件、嵌入式、机器人控制、传感器论文检索。
IEEE_XPLORE_API_KEY=

# The Lens：专利、论文和发明人线索，适合 AI 硬件和机器人硬件人才发现。
LENS_API_KEY=

# ================================
# 新增建议：开发者社区 / 社媒 / 内容平台
# ================================
# X/Twitter：公开帖子近期搜索，用于发现技术讨论、demo、开源发布和候选人动态。
X_BEARER_TOKEN=

# X/Twitter OAuth 2.0：需要用户授权、刷新 token 或访问用户上下文能力时使用。
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=

# X/Twitter OAuth 1.0a：部分旧端点、用户上下文或第三方 SDK 仍可能要求这组凭据。
X_API_KEY=
X_API_SECRET=
X_USER_ACCESS_TOKEN=
X_USER_ACCESS_TOKEN_SECRET=

# X/Twitter 监控范围：用于限定重点 KOL、社区成员、列表成员或目标账号。
# 多个 ID 用英文逗号分隔，不要放用户名显示名。
X_MONITORED_USER_IDS=
X_MONITORED_LIST_IDS=

# Reddit：技术社区讨论检索。必须使用 OAuth app 和明确 User-Agent。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# YouTube：演讲、demo、机器人真机视频、技术频道检索。
YOUTUBE_API_KEY=

# Stack Exchange / Stack Overflow：问答和高声誉技术用户线索。
STACKEXCHANGE_KEY=
STACKEXCHANGE_ACCESS_TOKEN=

# ================================
# 新增建议：联系人发现 / 商业数据补全
# ================================
# Apollo：B2B 联系人和公司库，用于找公开商业联系方式和岗位相关联系人。
APOLLO_API_KEY=

# People Data Labs：人员/公司数据补全和身份合并。使用前确认数据授权和地域合规。
PDL_API_KEY=

# Crustdata：实时/新鲜度更强的 B2B 人员、公司、融资、招聘和增长信号。
CRUSTDATA_API_KEY=

# Coresignal：公司、员工、职位和商业数据补全备选，适合和 PDL/Crustdata 交叉校验。
CORESIGNAL_API_KEY=

# Proxycurl：公开职业资料补全备选。使用前确认 LinkedIn/地区合规边界。
PROXYCURL_API_KEY=

# Hunter：按公司域名和姓名查找工作邮箱，并可做邮箱验证。
HUNTER_API_KEY=

# ================================
# 新增建议：合规网页抓取 / 浏览器自动化基础设施
# ================================
# Apify：Actor/爬虫运行平台，可用于网页、社媒和招聘站点的合规采集任务。
APIFY_API_TOKEN=

# Bright Data：Web Unlocker / SERP / 数据集服务。使用前确认目标网站条款和地区合规。
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=

# Browserbase：云浏览器会话，适合 Browser-use/CDP 类自动化的托管运行环境。
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Firecrawl：网页抓取转 Markdown/API，适合公司官网、博客、文档和候选人主页抽取。
FIRECRAWL_API_KEY=

# Scrapfly：反爬处理、JS 渲染和网页抓取 API 备选。
SCRAPFLY_API_KEY=

# ================================
# 新增建议：邮箱验证 / 域名信誉保护
# ================================
# ZeroBounce：验证邮箱有效性，降低退信率。
ZEROBOUNCE_API_KEY=

# NeverBounce：邮箱验证备选。
NEVERBOUNCE_API_KEY=

# ================================
# 新增建议：直接触达 / 邮件发送
# ================================
# SendGrid：招聘触达邮件发送、事件回调和退信处理。
SENDGRID_API_KEY=

# Postmark：事务型/触达邮件发送，送达质量较稳定。
POSTMARK_SERVER_TOKEN=

# Mailtrap：测试环境真实 SMTP 沙箱。APP_ENV=test 时优先使用。
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USERNAME=
MAILTRAP_SMTP_PASSWORD=

# Mailgun：邮件发送、退信和事件追踪。
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Resend：邮件发送备选，适合简单工程集成。
RESEND_API_KEY=

# Gmail API：使用公司 Google Workspace 邮箱发信。需要 OAuth 授权。
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# Microsoft Graph：使用 Microsoft 365 / Outlook 邮箱发信。需要 Azure App 凭据。
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_SENDER_EMAIL=

# ================================
# 新增建议：ATS / CRM / 招聘管道
# ================================
# Greenhouse：候选人、职位、面试和招聘流程数据。
GREENHOUSE_HARVEST_API_KEY=

# Lever：候选人、opportunity、posting、面试和反馈。
LEVER_API_KEY=

# Ashby：候选人、职位、管道和招聘分析。
ASHBY_API_KEY=

# HubSpot：候选人或潜在人脉 CRM 管理。
HUBSPOT_PRIVATE_APP_TOKEN=

# ================================
# 新增建议：预约面试 / 日程
# ================================
# Calendly：候选人自助约面、取消、改期和 webhook。
CALENDLY_API_TOKEN=

# ================================
# 新增建议：LinkedIn 合规集成
# ================================
# LinkedIn Talent Solutions / CRM Connect / Recruiter System Connect。
# 这些不是通用爬人 API，通常需要 LinkedIn partner/企业授权。
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# ================================
# 新增建议：合规触达 / 退订 / 审计
# ================================
# 对外招聘落地页和隐私说明。海外冷邮件应说明公司身份、数据来源、用途和删除方式。
COMPANY_RECRUITING_SITE_URL=
PRIVACY_NOTICE_URL=
RECRUITING_CONTACT_EMAIL=

# 退订链接根地址和 suppression list 存储。任何退订/拒绝必须写入黑名单。
UNSUBSCRIBE_BASE_URL=
SUPPRESSION_LIST_DB_URL=

# 触达风控：建议默认需要人工确认，并限制每日发送量。
OUTREACH_REQUIRE_HUMAN_APPROVAL=true
OUTREACH_DAILY_LIMIT=50
DATA_RETENTION_DAYS=180

# ================================
# 数据库 / 持久化
# ================================
# 任务和事件持久化。留空时应用会回退到 sqlite:///data/tasks.sqlite3。
TASK_DATABASE_URL=

# scripts/create_db.py 初始化 PostgreSQL schema 时使用。
# 示例：postgresql+psycopg://user:pass@localhost:5432/robot_agent
DATABASE_URL=

# ================================
# 预留：GitHub App
# ================================
# 当前 github_repositories provider 不读取这些变量。需要先接入 provider 支持。
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_WEBHOOK_SECRET=
