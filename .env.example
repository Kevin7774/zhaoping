# Zhaoping 本地环境变量模板。
# 只把真实值填写到 .env。不要把真实密钥提交到 git。

# 本地 env 文件路径。默认读取项目根目录 .env。
ROBOT_AGENT_ENV_PATH=

# 本地运行环境。production/prod 会要求 PostgreSQL 和 AUTH_TOKEN_SECRET。
APP_ENV=

# 生产或外部访问时配置；本地开发未设置时会使用开发密钥。
AUTH_TOKEN_SECRET=

# 可选：限制登录邮箱域名，多个域名用英文逗号分隔。
COMPANY_EMAIL_DOMAINS=
ALLOW_PUBLIC_EMAIL_LOGIN=

# 是否允许非本机请求写入 env。默认不要开启；公开/Cloudflare 访问时保持为空。
ALLOW_REMOTE_ENV_SAVE=

# ================================
# 基础大模型 / 评估能力
# ================================
# OpenRouter：默认大模型 provider。
# 对应服务：openrouter_auto_reasoning、openrouter_online_research、openrouter_evidence_judge。
OPENROUTER_API_KEY=

# 单个长链路任务的累计 Token 预算。超过后 JSON workflow 会熔断并等待人工处理。
ZHAOPING_TASK_TOKEN_BUDGET=50000

# ================================
# OCR / 文档解析
# ================================
# 阿里云 OCR：简历、图片、扫描件文本识别。
# 对应服务：aliyun_ocr。
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ================================
# 已接入搜索：开放网页 / 代码 / 模型 / 监管 / 招聘信号
# ================================
# Brave Web Search：开放网页证据检索。
# 对应服务：brave_web_search。
BRAVE_SEARCH_API_KEY=

# GitHub：候选人、用户、仓库、代码和 topic 搜索，用于找公开技术作品、贡献者、语言和技术栈信号。
# 对应服务：github_candidates、github_users、github_repositories、github_code、github_topics。
# 当前使用个人访问令牌；GitHub App 需要另接 installation token。设置 GITHUB_SEARCH_ENABLED=false 可关闭 token 必需的 GitHub 搜人链路。
GITHUB_TOKEN=
GITHUB_SEARCH_ENABLED=true

# Hugging Face：模型生态搜索，用于找模型作者、下载量、标签和任务类型。
# 对应服务：huggingface_models。
HF_TOKEN=

# GNews：融资、并购、投资和新闻事件。
# 对应服务：gnews_funding_news。
GNEWS_API_KEY=

# OpenCLI / Agent-Reach 平台搜索不需要在本模板里配置 X/Reddit/公众号 API key；
# 需要本机命令和浏览器授权态。X/Twitter 已登录后由 OpenCLI browser bridge 使用。

# ================================
# 数据库 / 持久化
# ================================
# 项目、岗位、候选人、组织和用户持久化。留空时本地开发回退到 sqlite:///data/projects.sqlite3。
PROJECT_DATABASE_URL=

# scripts/create_db.py 初始化 PostgreSQL schema 时使用，也可作为 PROJECT_DATABASE_URL 兜底。
DATABASE_URL=

# 任务和事件持久化。留空时应用会回退到 sqlite:///data/tasks.sqlite3。
TASK_DATABASE_URL=

# 生产环境如需临时允许 SQLite，显式设置为 1；默认不要开启。
ALLOW_SQLITE_IN_PRODUCTION=

# 可选：搜索证据归档路径、workflow artifact 路径和候选人自动搜索调度器。
INTELLIGENCE_ARCHIVE_PATH=
WORKFLOW_ARTIFACT_DIR=
CANDIDATE_SEARCH_SCHEDULER_ENABLED=1
CANDIDATE_SEARCH_SCHEDULER_POLL_SECONDS=

# 可选：PDF 文本抽取 fallback。
ZHAOPING_ALLOW_PDF_TEXT_FALLBACK=
